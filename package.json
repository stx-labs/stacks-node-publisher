{
  "name": "stacks-node-publisher",
  "version": "2.1.2",
  "description": "Store-and-push service for Stacks node events",
  "type": "module",
  "scripts": {
    "build": "rimraf ./dist && tsc --project tsconfig.build.json",
    "build:tests": "tsc -p tsconfig.json --noEmit",
    "start": "node ./dist/src/index.js",
    "start-ts": "tsx ./src/index.ts",
    "test:client-stream": "NODE_ENV=test node --import tsx --test --test-global-setup=./tests/setup.ts --test-concurrency=1 ./tests/client-stream/**/*.test.ts",
    "test:event-server": "NODE_ENV=test node --import tsx --test --test-global-setup=./tests/setup.ts --test-concurrency=1 ./tests/event-server/**/*.test.ts",
    "test:redis-broker": "NODE_ENV=test node --import tsx --test --test-global-setup=./tests/setup.ts --test-concurrency=1 ./tests/redis-broker/**/*.test.ts",
    "migrate": "tsx node_modules/.bin/node-pg-migrate -j ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "generate:git-info": "rimraf .git-info && node_modules/.bin/api-toolkit-git-info"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stx-labs/stacks-node-publisher.git"
  },
  "author": "Stacks Labs",
  "license": "GPL-3.0",
  "bugs": {
    "url": "https://github.com/stx-labs/stacks-node-publisher/issues"
  },
  "homepage": "https://github.com/stx-labs/stacks-node-publisher#readme",
  "prettier": "@stacks/prettier-config",
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@stacks/api-test-toolkit": "^1.13.0",
    "@stacks/eslint-config": "3.0.0-develop.2",
    "@types/dockerode": "^4.0.1",
    "@types/node": "^24.12.2",
    "@types/supertest": "^6.0.2",
    "eslint": "10.1.0",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-tsdoc": "0.5.2",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@stacks/api-toolkit": "^1.13.0",
    "env-schema": "^7.0.0",
    "fastify": "^5.8.5",
    "fastify-metrics": "^13.2.0",
    "node-pg-migrate": "^7.8.0",
    "p-queue": "^9.1.2",
    "postgres": "^3.4.9",
    "redis": "^5.12.1"
  }
}
