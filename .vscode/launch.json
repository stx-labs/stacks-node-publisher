{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Run",
      "runtimeArgs": [
        "--import",
        "tsx"
      ],
      "args": [
        "${workspaceFolder}/src/index.ts"
      ],
      "outputCapture": "std",
      "internalConsoleOptions": "openOnSessionStart",
      "env": {
        "NODE_ENV": "development",
        "NETWORK": "testnet",
        "PGDATABASE": "postgres",
        "PGHOST": "127.0.0.1",
        "PGPORT": "6433",
        "PGUSER": "postgres",
        "PGPASSWORD": "postgres",
        "REDIS_URL": "redis://127.0.0.1:7379",
      },
      "killBehavior": "polite",
      "preLaunchTask": "npm: testenv:run",
      "postDebugTask": "npm: testenv:stop",
    },
    {
      "type": "node",
      "request": "launch",
      "name": "test: event-server",
      "runtimeExecutable": "node",
      "args": [
        "--import",
        "tsx",
        "--test",
        "--test-global-setup=./tests/setup.ts",
        "--test-concurrency=1",
        "./tests/event-server/**/*.test.ts"
      ],
      "outputCapture": "std",
      "console": "integratedTerminal",
      "env": {
        "NODE_ENV": "test"
      }
    },
    {
      "type": "node",
      "request": "launch",
      "name": "test: redis-broker",
      "runtimeExecutable": "node",
      "args": [
        "--import",
        "tsx",
        "--test",
        "--test-global-setup=./tests/setup.ts",
        "--test-concurrency=1",
        "./tests/redis-broker/**/*.test.ts"
      ],
      "outputCapture": "std",
      "console": "integratedTerminal",
      "env": {
        "NODE_ENV": "test"
      }
    },
    {
      "type": "node",
      "request": "launch",
      "name": "test: client-stream",
      "runtimeExecutable": "node",
      "args": [
        "--import",
        "tsx",
        "--test",
        "--test-global-setup=./tests/setup.ts",
        "--test-concurrency=1",
        "./tests/client-stream/**/*.test.ts"
      ],
      "outputCapture": "std",
      "console": "integratedTerminal",
      "env": {
        "NODE_ENV": "test"
      }
    },
  ]
}
